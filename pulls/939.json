      "following_url": "https://api.github.com/users/ShauryaaSharma/following%7B/other_user%7D",
      "gists_url": "https://api.github.com/users/ShauryaaSharma/gists%7B/gist_id%7D",
      "starred_url": "https://api.github.com/users/ShauryaaSharma/starred%7B/owner%7D%7B/repo%7D",
      "subscriptions_url": "https://api.github.com/users/ShauryaaSharma/subscriptions",
      "organizations_url": "https://api.github.com/users/ShauryaaSharma/orgs",
      "repos_url": "https://api.github.com/users/ShauryaaSharma/repos",
      "events_url": "https://api.github.com/users/ShauryaaSharma/events%7B/privacy%7D",
