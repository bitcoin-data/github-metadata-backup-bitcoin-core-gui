    "maintainer_can_modify": true,
    "title": "gui: show wallet name in progress messages",
    "user": {
      "login": "ShauryaaSharma",
      "id": 196896785,
      "node_id": "U_kgDOC7xoEQ",
      "avatar_url": "https://avatars.githubusercontent.com/u/196896785?v=4",
      "gravatar_id": "",
      "url": "https://api.github.com/users/ShauryaaSharma",
      "html_url": "https://github.com/ShauryaaSharma",
